<!DOCTYPE html>
<html>
<head>
    <title>Mes Messages</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .messages-container {
            max-width: 800px;
            margin: 0 auto;
        }

        /* HEADER */
        .messages-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 40px 30px;
            border-radius: 15px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            text-align: center;
        }

        .messages-header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
            font-weight: 700;
        }

        .messages-header p {
            font-size: 1em;
            opacity: 0.9;
        }

        /* MESSAGES SECTION */
        .messages-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            overflow: hidden;
            margin-bottom: 30px;
        }

        .messages-list {
            padding: 30px;
            max-height: 500px;
            overflow-y: auto;
        }

        .message-item {
            margin-bottom: 20px;
            padding: 15px;
            border-radius: 10px;
            display: flex;
            flex-direction: column;
            animation: slideIn 0.3s ease-out;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .message-admin {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            margin-right: 40px;
        }

        .message-guide {
            background: #f0f0f5;
            color: #333;
            margin-left: 40px;
            border-left: 4px solid #667eea;
        }

        .message-sender {
            font-weight: 700;
            font-size: 0.9em;
            margin-bottom: 5px;
            opacity: 0.9;
        }

        .message-content {
            font-size: 1em;
            line-height: 1.4;
            margin-bottom: 8px;
        }

        .message-time {
            font-size: 0.75em;
            opacity: 0.7;
        }

        .empty-state {
            text-align: center;
            padding: 60px 30px;
            color: #999;
        }

        .empty-state-icon {
            font-size: 3em;
            margin-bottom: 15px;
        }

        .empty-state-message {
            font-size: 1.2em;
            color: #666;
        }

        /* BUTTON */
        .btn-container {
            padding: 20px 30px;
            display: flex;
            gap: 15px;
        }

        .btn {
            padding: 12px 30px;
            border: none;
            border-radius: 8px;
            font-size: 1em;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all 0.3s;
            flex: 1;
            text-align: center;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

        .btn-secondary {
            background: white;
            color: #667eea;
            border: 2px solid #667eea;
        }

        .btn-secondary:hover {
            background: #f8f9fa;
        }

        @media (max-width: 600px) {
            .messages-header { padding: 30px 20px; }
            .messages-header h1 { font-size: 1.8em; }
            .message-item { margin-right: 0; margin-left: 0; }
            .btn-container { flex-direction: column; }
        }
    </style>
</head>
<body>
    <div class="messages-container">
        <!-- HEADER -->
        <div class="messages-header">
            <h1>📨 Mes Messages</h1>
            <p>Conversations sécurisées</p>
        </div>

        <!-- MESSAGES CARD -->
        <div class="messages-card">
            <div class="messages-list">
                <div class="empty-state">
                    <div class="empty-state-icon">💬</div>
                    <div class="empty-state-message">✅ Page marche parfaitement !</div>
                </div>
            </div>
            <div class="btn-container">
                <a href="/guide/dashboard" class="btn btn-secondary">← Retour Dashboard</a>
            </div>
        </div>
    </div>
</body>
</html>
