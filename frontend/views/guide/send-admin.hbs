<!DOCTYPE html>
<html>
<head>
    <title>Envoyer Message Admin</title>
    <link href="https://cdn.tailwindcss.com" rel="stylesheet">
</head>
<body class="bg-gradient-to-br from-gray-100 to-gray-200 min-h-screen">
    <div class="max-w-2xl mx-auto px-6 py-8">
        <div class="bg-white rounded-2xl shadow-lg p-8">
            <h1 class="text-2xl font-bold mb-6">✉️ Envoyer Message à Admin</h1>
            
            <form method="POST" action="/guide/send-message-admin" class="space-y-4">
                <textarea name="message" placeholder="Votre message pour l'admin..." required
                          class="w-full p-4 border-2 border-gray-300 rounded-xl focus:border-blue-500 focus:outline-none resize-none" 
                          rows="6"></textarea>
                <button type="submit" class="w-full bg-gradient-to-r from-blue-500 to-purple-600 
                           text-white text-center py-4 px-6 rounded-xl font-bold text-lg shadow-xl hover:shadow-2xl transform hover:-translate-y-1 transition-all">
                    📨 Envoyer Message
                </button>
            </form>
            
            <div class="mt-6">
                <a href="/guide/messages" class="text-blue-600 hover:text-blue-800">← Retour aux messages</a>
            </div>
        </div>
    </div>
</body>
</html>
