<!DOCTYPE html>
<html lang="fr">
<head>
    <title>Messages Admin</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .messages-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            display: flex;
            align-items: center;
            gap: 15px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .messages-header a {
            font-size: 1.8em;
            color: white;
            text-decoration: none;
            transition: all 0.3s;
        }

        .messages-header a:hover {
            opacity: 0.8;
        }

        .admin-info {
            flex: 1;
        }

        .admin-name {
            font-size: 1.3em;
            margin-bottom: 5px;
        }

        .admin-role {
            font-size: 0.9em;
            opacity: 0.8;
        }

        .messages-container {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            max-width: 800px;
            margin: 0 auto;
            width: 100%;
        }

        .message-item {
            margin-bottom: 20px;
            padding: 15px 20px;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            max-width: 70%;
            animation: slideIn 0.3s ease-out;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .message-admin {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            align-self: flex-start;
            margin-left: 0;
            border-bottom-left-radius: 4px;
            box-shadow: 0 3px 10px rgba(102, 126, 234, 0.3);
        }

        .message-guide {
            background: white;
            color: #333;
            align-self: flex-end;
            margin-right: 0;
            border: 1px solid #e0e0e0;
            border-bottom-right-radius: 4px;
            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.08);
        }

        .message-content {
            font-size: 1em;
            line-height: 1.4;
            margin-bottom: 8px;
            word-wrap: break-word;
        }

        .message-time {
            font-size: 0.75em;
            opacity: 0.7;
        }

        .message-input-section {
            background: white;
            border-top: 1px solid #e0e0e0;
            padding: 15px 20px;
            position: sticky;
            bottom: 0;
            box-shadow: 0 -3px 10px rgba(0,0,0,0.08);
        }

        .message-form {
            display: flex;
            gap: 10px;
            max-width: 800px;
            margin: 0 auto;
            width: 100%;
        }

        .message-form input {
            flex: 1;
            padding: 12px 18px;
            border: 2px solid #e0e0e0;
            border-radius: 25px;
            font-size: 1em;
            font-family: inherit;
            transition: all 0.3s;
            background: #f8f9fa;
        }

        .message-form input:focus {
            outline: none;
            border-color: #667eea;
            background: white;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .message-form button {
            padding: 12px 20px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 25px;
            font-size: 1.2em;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            min-width: 50px;
        }

        .message-form button:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

        .empty-messages {
            text-align: center;
            padding: 80px 20px;
            color: #999;
        }

        .empty-messages-icon {
            font-size: 4em;
            margin-bottom: 15px;
        }

        .empty-messages-text {
            font-size: 1.2em;
            color: #666;
        }

        @media (max-width: 600px) {
            .messages-header { padding: 15px 20px; }
            .admin-name { font-size: 1.1em; }
            .message-item { max-width: 85%; }
            .messages-container { padding: 10px; }
        }
    </style>
</head>
<body>
    <!-- HEADER -->
    <div class="messages-header">
        <a href="/guide/dashboard">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div class="admin-info">
            <div class="admin-name">
                <i class="fas fa-user-shield"></i>
                {{#if admin}}{{admin.nom_complet}}{{else}}Administrateur{{/if}}
            </div>
            <div class="admin-role">Administration</div>
        </div>
    </div>

    <!-- MESSAGES -->
    <div class="messages-container">
        {{#if messages.length}}
            {{#each messages}}
                <div class="message-item {{#if (eq id_expediteur ../user.id)}}message-guide{{else}}message-admin{{/if}}">
                    <div class="message-content">{{contenu}}</div>
                    <div class="message-time">{{formatDate date_creation}}</div>
                </div>
            {{/each}}
        {{else}}
            <div class="empty-messages">
                <div class="empty-messages-icon">
                    <i class="fas fa-comments"></i>
                </div>
                <div class="empty-messages-text">Aucun message pour le moment</div>
                <p style="margin-top: 10px; font-size: 0.9em;">Commencez la conversation avec l'administrateur</p>
            </div>
        {{/if}}
    </div>

    <!-- INPUT SECTION -->
    <div class="message-input-section">
        <form class="message-form" action="/guide/send-message" method="POST">
            <input type="text" name="contenu" placeholder="Tapez votre message..." required>
            <button type="submit">
                <i class="fas fa-paper-plane"></i>
            </button>
        </form>
    </div>

    <script>
        // Auto-scroll vers le bas
        function scrollToBottom() {
            const container = document.querySelector('.messages-container');
            container.scrollTop = container.scrollHeight;
        }

        // Formatter la date
        function formatDate(dateString) {
            const date = new Date(dateString);
            const now = new Date();
            const diff = now - date;
            
            if (diff < 60000) return 'À l\'instant';
            if (diff < 3600000) return `${Math.floor(diff / 60000)} min`;
            if (diff < 86400000) return `${Math.floor(diff / 3600000)} h`;
            if (diff < 604800000) return `${Math.floor(diff / 86400000)} j`;
            
            return date.toLocaleDateString('fr-FR', { 
                day: 'numeric', 
                month: 'short', 
                hour: '2-digit', 
                minute: '2-digit' 
            });
        }

        // Helper pour Handlebars
        if (typeof Handlebars !== 'undefined') {
            Handlebars.registerHelper('formatDate', formatDate);
            Handlebars.registerHelper('eq', function(a, b) {
                return a === b;
            });
        }

        // Scroler au chargement et après envoi
        document.addEventListener('DOMContentLoaded', () => {
            scrollToBottom();
            
            // Scroller après chaque nouveau message
            const observer = new MutationObserver(() => {
                scrollToBottom();
            });
            
            observer.observe(document.querySelector('.messages-container'), {
                childList: true,
                subtree: true
            });
        });

        // Focus sur le champ input
        document.querySelector('input[name="contenu"]').focus();
    </script>
</body>
</html>
