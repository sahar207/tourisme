<!DOCTYPE html>
<html>
<head>
  <title>Upload CV - Guide</title>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f5f6fa; }
    
    .container { max-width: 800px; margin: 0 auto; padding: 20px; }
    
    .header { 
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); 
      color: white; padding: 30px; border-radius: 15px; 
      text-align: center; margin-bottom: 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }
    
    .upload-card { 
      background: white; padding: 40px; 
      border-radius: 15px; box-shadow: 0 5px 20px rgba(0,0,0,0.1);
      margin-bottom: 20px;
    }
    
    .form-group { margin-bottom: 25px; }
    .form-group label { 
      display: block; margin-bottom: 10px; font-weight: 600; 
      color: #2c3e50; font-size: 1.1em;
    }
    
    .file-input-wrapper {
      position: relative; overflow: hidden; display: inline-block;
      width: 100%;
    }
    
    .file-input-wrapper input[type=file] {
      position: absolute; left: -9999px;
    }
    
    .file-input-button {
      display: block; width: 100%; padding: 20px;
      background: #f8f9fa; border: 2px dashed #dee2e6;
      border-radius: 10px; text-align: center; cursor: pointer;
      transition: all 0.3s; font-size: 1.1em;
    }
    
    .file-input-button:hover {
      background: #e9ecef; border-color: #667eea;
    }
    
    .file-input-button.has-file {
      background: #d4edda; border-color: #28a745; color: #155724;
    }
    
    .submit-btn {
      width: 100%; padding: 15px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white; border: none; border-radius: 10px; font-size: 1.1em;
      font-weight: 600; cursor: pointer; transition: all 0.3s;
    }
    
    .submit-btn:hover {
      transform: translateY(-2px); box-shadow: 0 5px 20px rgba(102, 126, 234, 0.4);
    }
    
    .submit-btn:disabled {
      background: #6c757d; cursor: not-allowed; transform: none;
    }
    
    .alert {
      padding: 15px 20px; border-radius: 10px; margin-bottom: 20px;
      font-weight: 500;
    }
    
    .alert-success {
      background: #d4edda; color: #155724; border: 1px solid #c3e6cb;
    }
    
    .alert-error {
      background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb;
    }
    
    .status-info {
      background: #e3f2fd; padding: 20px; border-radius: 10px;
      margin-bottom: 20px; border-left: 4px solid #2196f3;
    }
    
    .status-info h4 { color: #1976d2; margin-bottom: 10px; }
    
    .back-link {
      display: inline-block; margin-top: 20px; padding: 10px 20px;
      background: #6c757d; color: white; text-decoration: none;
      border-radius: 8px; transition: all 0.3s;
    }
    
    .back-link:hover {
      background: #5a6268; transform: translateY(-1px);
    }
    
    .file-info {
      margin-top: 10px; padding: 10px; background: #f8f9fa;
      border-radius: 5px; font-size: 0.9em; color: #666;
    }
    
    .requirements {
      background: #fff3cd; padding: 15px; border-radius: 8px;
      margin-bottom: 20px; border-left: 4px solid #ffc107;
    }
    
    .requirements h5 { color: #856404; margin-bottom: 10px; }
    .requirements ul { color: #856404; margin-left: 20px; }
  </style>
</head>
<body>
  <div class="container">
    <!-- Header -->
    <div class="header">
      <h1>📄 Upload CV et Diplôme</h1>
      <p>Déposez votre CV et diplôme pour validation par l'administration</p>
    </div>

    <!-- Alertes -->
    {{#if success}}
    <div class="alert alert-success">
      ✅ {{success}}
    </div>
    {{/if}}
    
    {{#if error}}
    <div class="alert alert-error">
      ❌ {{error}}
    </div>
    {{/if}}

    <!-- Status actuel -->
    <div class="status-info">
      <h4>📊 Statut Actuel</h4>
      <p><strong>Nom:</strong> {{user.nom_complet}}</p>
      <p><strong>Email:</strong> {{user.email}}</p>
      {{#if guide.cv}}
      <p><strong>CV actuel:</strong> 
        {{#if guide.cv_approved}}
        <span style="color: #28a745;">✅ Approuvé</span>
        {{else}}
        <span style="color: #ffc107;">⏳ En attente de validation</span>
        {{/if}}
      </p>
      {{else}}
      <p><strong>CV:</strong> <span style="color: #dc3545;">❌ Non déposé</span></p>
      {{/if}}
      {{#if guide.diplome}}
      <p><strong>Diplôme actuel:</strong> 
        {{#if guide.diplome_approved}}
        <span style="color: #28a745;">✅ Approuvé</span>
        {{else}}
        <span style="color: #ffc107;">⏳ En attente de validation</span>
        {{/if}}
      </p>
      {{else}}
      <p><strong>Diplôme:</strong> <span style="color: #dc3545;">❌ Non déposé</span></p>
      {{/if}}
    </div>

    <!-- Upload Form -->
    <div class="upload-card">
      <h2 style="margin-bottom: 20px; color: #2c3e50;">📤 Déposer votre CV et Diplôme</h2>
      
      <!-- Requirements -->
      <div class="requirements">
        <h5>📋 Conditions requises:</h5>
        <ul>
          <li>Format: PDF, DOC, ou DOCX</li>
          <li>Taille maximale: 5MB par fichier</li>
          <li>CV: Informations professionnelles complètes</li>
          <li>Diplôme: Justificatif de qualification</li>
          <li>Langue: Français ou Anglais</li>
        </ul>
      </div>

      <form action="/guide/documents/upload" method="POST" enctype="multipart/form-data" id="uploadForm">
        <div class="form-group">
          <label for="cv_file">Sélectionner votre CV:</label>
          <div class="file-input-wrapper">
            <input type="file" name="cv" id="cv_file" accept=".pdf,.doc,.docx" required>
            <label for="cv_file" class="file-input-button" id="cvLabel">
              📁 Cliquez pour choisir votre CV ou glissez-déposez ici
            </label>
            <div class="file-info" id="cvInfo" style="display: none;"></div>
          </div>
        </div>

        <div class="form-group">
          <label for="diplome_file">Sélectionner votre Diplôme:</label>
          <div class="file-input-wrapper">
            <input type="file" name="diplome" id="diplome_file" accept=".pdf,.doc,.docx" required>
            <label for="diplome_file" class="file-input-button" id="diplomeLabel">
              📁 Cliquez pour choisir votre diplôme ou glissez-déposez ici
            </label>
            <div class="file-info" id="diplomeInfo" style="display: none;"></div>
          </div>
        </div>

        <button type="submit" class="submit-btn" id="submitBtn">
          📤 Envoyer mes documents
        </button>
      </form>
    </div>

    <!-- Actions supplémentaires -->
    <div style="text-align: center;">
      <a href="/guide/profile" class="back-link">← Retour au profil</a>
    </div>
  </div>

  <script>
    // File input handling
    const cvInput = document.getElementById('cv_file');
    const cvLabel = document.getElementById('cvLabel');
    const cvInfo = document.getElementById('cvInfo');
    
    const diplomeInput = document.getElementById('diplome_file');
    const diplomeLabel = document.getElementById('diplomeLabel');
    const diplomeInfo = document.getElementById('diplomeInfo');
    
    const submitBtn = document.getElementById('submitBtn');
    const uploadForm = document.getElementById('uploadForm');

    function handleFileInput(fileInput, fileLabel, fileInfo) {
      fileInput.addEventListener('change', function(e) {
        const file = e.target.files[0];
        
        if (file) {
          // Vérifier la taille
          if (file.size > 5 * 1024 * 1024) {
            alert('Le fichier est trop volumineux (max 5MB)');
            fileInput.value = '';
            return;
          }

          // Vérifier le type
          const allowedTypes = ['application/pdf', 'application/msword', 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'];
          if (!allowedTypes.includes(file.type)) {
            alert('Format de fichier non supporté (PDF, DOC, DOCX uniquement)');
            fileInput.value = '';
            return;
          }

          // Mettre à jour l'interface
          fileLabel.classList.add('has-file');
          fileLabel.innerHTML = `✅ ${file.name} (${(file.size / 1024 / 1024).toFixed(2)} MB)`;
          
          fileInfo.innerHTML = `
            <strong>Fichier sélectionné:</strong> ${file.name}<br>
            <strong>Taille:</strong> ${(file.size / 1024 / 1024).toFixed(2)} MB<br>
            <strong>Type:</strong> ${file.type}
          `;
          fileInfo.style.display = 'block';
          
          checkFormValidity();
        } else {
          resetFileInput(fileInput, fileLabel, fileInfo);
        }
      });
    }

    function resetFileInput(fileInput, fileLabel, fileInfo) {
      fileLabel.classList.remove('has-file');
      fileLabel.innerHTML = fileInput.id === 'cv_file' ? '📁 Cliquez pour choisir votre CV ou glissez-déposez ici' : '📁 Cliquez pour choisir votre diplôme ou glissez-déposez ici';
      fileInfo.style.display = 'none';
      checkFormValidity();
    }

    function checkFormValidity() {
      const cvSelected = cvInput.files.length > 0;
      const diplomeSelected = diplomeInput.files.length > 0;
      submitBtn.disabled = !(cvSelected && diplomeSelected);
    }

    // Initialize file handlers
    handleFileInput(cvInput, cvLabel, cvInfo);
    handleFileInput(diplomeInput, diplomeLabel, diplomeInfo);

    // Initial check
    checkFormValidity();

    // Drag and drop for CV
    const cvDropZone = cvLabel;
    cvDropZone.addEventListener('dragover', function(e) {
      e.preventDefault();
      cvDropZone.style.background = '#e3f2fd';
    });

    cvDropZone.addEventListener('dragleave', function(e) {
      e.preventDefault();
      cvDropZone.style.background = '#f8f9fa';
    });

    cvDropZone.addEventListener('drop', function(e) {
      e.preventDefault();
      cvDropZone.style.background = '#f8f9fa';
      
      const files = e.dataTransfer.files;
      if (files.length > 0) {
        cvInput.files = files;
        cvInput.dispatchEvent(new Event('change'));
      }
    });

    // Drag and drop for Diplôme
    const diplomeDropZone = diplomeLabel;
    diplomeDropZone.addEventListener('dragover', function(e) {
      e.preventDefault();
      diplomeDropZone.style.background = '#e3f2fd';
    });

    diplomeDropZone.addEventListener('dragleave', function(e) {
      e.preventDefault();
      diplomeDropZone.style.background = '#f8f9fa';
    });

    diplomeDropZone.addEventListener('drop', function(e) {
      e.preventDefault();
      diplomeDropZone.style.background = '#f8f9fa';
      
      const files = e.dataTransfer.files;
      if (files.length > 0) {
        diplomeInput.files = files;
        diplomeInput.dispatchEvent(new Event('change'));
      }
    });

    // Form submission
    uploadForm.addEventListener('submit', function(e) {
      submitBtn.disabled = true;
      submitBtn.innerHTML = '⏳ Envoi en cours...';
      
      // Le formulaire sera soumis normalement
    });

    // Initialize
    checkFormValidity();
  </script>
</body>
</html>
