<!DOCTYPE html>
<html>
<head>
    <title>Chat Admin</title>
    <link href="https://cdn.tailwindcss.com" rel="stylesheet">
    <style>
        .bubble { max-width: 70%; padding: 10px 15px; margin: 6px 12px; border-radius: 20px; position: relative; }
        .received { background: #ffffff; color: #333; margin-left: 40px; border-bottom-left-radius: 4px; box-shadow: 0 1px 2px rgba(0,0,0,0.1); }
        .sent { background: #1877f2; color: white; margin-right: 40px; border-bottom-right-radius: 4px; margin-left: auto; }
        .time { font-size: 11px; opacity: 0.8; margin-top: 4px; }
    </style>
</head>
<body class="bg-gradient-to-b from-gray-50 to-gray-200 min-h-screen">
    
    <!-- Header Messenger -->
    <div class="bg-white shadow-lg border-b sticky top-0">
        <div class="max-w-lg mx-auto px-4 py-3">
            <div class="flex items-center">
                <a href="/guide/dashboard" class="text-2xl mr-4 hover:text-blue-500">←</a>
                <div>
                    <h2 class="font-bold text-lg">Administration</h2>
                    <p class="text-sm text-green-500">en ligne</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Messages Container -->
    <div class="max-w-lg mx-auto px-4 flex-1" style="height: calc(100vh - 140px); overflow-y: auto;">
        {{#each messages}}
        {{#if eq sender_id 13}}
            <!-- Message ADMIN (reçu) -->
            <div class="received bubble">
                <div>{{contenu}}</div>
                <div class="time">{{date_creation}}</div>
            </div>
        {{else}}
            <!-- Message GUIDE (envoyé) -->
            <div class="sent bubble">
                <div>{{contenu}}</div>
                <div class="time">{{date_creation}}</div>
            </div>
        {{/if}}
        {{/each}}
        
        {{#unless messages.length}}
        <div class="text-center py-24 text-gray-500">
            <div class="w-20 h-20 bg-blue-100 rounded-full mx-auto mb-6 flex items-center justify-center text-3xl">💬</div>
            <h3 class="text-lg font-medium mb-2">Aucun message</h3>
            <p class="text-sm">Démarrez la conversation</p>
        </div>
        {{/unless}}
    </div>

    <!-- Input ENVOI -->
    <div class="bg-white shadow-2xl border-t sticky bottom-0 max-w-lg mx-auto p-4">
        <form action="/guide/chat/send" method="POST">
            <div class="flex items-end space-x-3">
                <input type="text" name="message" placeholder="Tapez un message..." 
                       class="flex-1 bg-gray-100 p-3 rounded-3xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white" 
                       required autocomplete="off">
                <button type="submit" class="bg-blue-500 hover:bg-blue-600 text-white p-3 rounded-3xl w-12 h-12 flex items-center justify-center shadow-lg">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                    </svg>
                </button>
            </div>
        </form>
    </div>
</body>
</html>
