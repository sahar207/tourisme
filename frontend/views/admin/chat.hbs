<!DOCTYPE html>
<html><head><title>Chat Guides</title><link href="https://cdn.tailwindcss.com" rel="stylesheet">
<style>.bubble{max-width:70%;padding:10px 15px;margin:6px 12px;border-radius:20px;}.received{background:#ffffff;color:#333;margin-left:40px;border-bottom-left-radius:4px;box-shadow:0 1px 2px rgba(0,0,0,0.1);}.sent{background:#1877f2;color:white;margin-right:40px;border-bottom-right-radius:4px;margin-left:auto;}</style></head><body class="bg-gray-100 min-h-screen">
<div class="bg-white shadow-lg border-b p-4"><a href="/admin/dashboard" class="text-2xl mb-2 block hover:text-blue-500">←</a><h1 class="text-2xl font-bold">Chat Guides</h1></div>
<div class="max-w-lg mx-auto px-4" style="height:calc(100vh - 160px);overflow-y:auto;">
{{#each messages}}
{{#if (eq id_expediteur 13)}}<div class="sent bubble"><div>{{contenu}}</div><div class="text-xs opacity-75 mt-1">{{date_creation}}</div></div>
{{else}}<div class="received bubble"><strong>{{sender_name}}:</strong> {{contenu}}<div class="text-xs opacity-75 mt-1">{{date_creation}}</div></div>{{/if}}
{{/each}}
</div>
<form action="/admin/chat/send" method="POST" class="bg-white shadow-2xl border-t p-4 max-w-lg mx-auto">
<input type="hidden" name="guide_id" value="9">
<div class="flex"><input name="message" placeholder="Répondre..." class="flex-1 bg-gray-100 p-3 rounded-2xl focus:outline-none focus:ring-2" required>
<button type="submit" class="ml-2 bg-blue-500 text-white px-4 py-3 rounded-2xl font-medium">Envoyer ➤</button></div>
</form></body></html>
