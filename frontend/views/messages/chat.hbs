<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Messages - {{user.nom_complet}}</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .chat-container {
            max-width: 1200px;
            margin: 0 auto;
            height: 100vh;
            display: flex;
            background: #f5f5f5;
        }

        .conversations-sidebar {
            width: 350px;
            background: white;
            border-right: 1px solid #e0e0e0;
            overflow-y: auto;
        }

        .chat-main {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: white;
        }

        .chat-header {
            padding: 20px;
            background: #2c3e50;
            color: white;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .chat-messages {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
            background: #f8f9fa;
        }

        .message {
            margin-bottom: 15px;
            display: flex;
            align-items: flex-start;
            gap: 10px;
        }

        .message.sent {
            flex-direction: row-reverse;
        }

        .message-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #3498db;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
            font-size: 14px;
        }

        .message-content {
            max-width: 70%;
            padding: 12px 16px;
            border-radius: 18px;
            background: #e9ecef;
            position: relative;
        }

        .message.sent .message-content {
            background: #3498db;
            color: white;
        }

        .message-time {
            font-size: 11px;
            opacity: 0.7;
            margin-top: 5px;
        }

        .chat-input {
            padding: 20px;
            border-top: 1px solid #e0e0e0;
            background: white;
        }

        .input-group {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .message-input {
            flex: 1;
            padding: 12px 20px;
            border: 1px solid #ddd;
            border-radius: 25px;
            outline: none;
            font-size: 14px;
        }

        .send-btn {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            border: none;
            background: #3498db;
            color: white;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.3s;
        }

        .send-btn:hover {
            background: #2980b9;
        }

        .conversation-item {
            padding: 15px 20px;
            border-bottom: 1px solid #f0f0f0;
            cursor: pointer;
            transition: background 0.2s;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .conversation-item:hover {
            background: #f8f9fa;
        }

        .conversation-item.active {
            background: #e3f2fd;
            border-left: 4px solid #3498db;
        }

        .conversation-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: #6c757d;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
        }

        .conversation-info {
            flex: 1;
        }

        .conversation-name {
            font-weight: 600;
            margin-bottom: 5px;
        }

        .conversation-last-message {
            font-size: 13px;
            color: #6c757d;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .conversation-meta {
            text-align: right;
            font-size: 12px;
            color: #6c757d;
        }

        .unread-badge {
            background: #e74c3c;
            color: white;
            border-radius: 10px;
            padding: 2px 8px;
            font-size: 11px;
            font-weight: bold;
        }

        .typing-indicator {
            padding: 10px 20px;
            color: #6c757d;
            font-style: italic;
            display: none;
        }

        .typing-indicator.active {
            display: block;
        }

        .file-upload-btn {
            background: none;
            border: none;
            color: #6c757d;
            cursor: pointer;
            padding: 10px;
            font-size: 18px;
        }

        .file-upload-btn:hover {
            color: #3498db;
        }

        .message-file {
            margin-top: 8px;
            padding: 8px 12px;
            background: rgba(0,0,0,0.05);
            border-radius: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
        }

        .message-file i {
            color: #3498db;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #6c757d;
        }

        .empty-state i {
            font-size: 64px;
            margin-bottom: 20px;
            opacity: 0.3;
        }

        .online-indicator {
            width: 12px;
            height: 12px;
            background: #27ae60;
            border-radius: 50%;
            border: 2px solid white;
            position: absolute;
            bottom: 2px;
            right: 2px;
        }

        @media (max-width: 768px) {
            .conversations-sidebar {
                width: 100%;
                position: absolute;
                z-index: 10;
                transform: translateX(-100%);
                transition: transform 0.3s;
            }

            .conversations-sidebar.show {
                transform: translateX(0);
            }

            .chat-main {
                margin-left: 0;
            }

            .mobile-menu-btn {
                display: block;
                position: fixed;
                top: 20px;
                left: 20px;
                z-index: 11;
                background: #3498db;
                color: white;
                border: none;
                border-radius: 50%;
                width: 45px;
                height: 45px;
                cursor: pointer;
            }
        }

        .mobile-menu-btn {
            display: none;
        }
    </style>
</head>
<body>
    <button class="mobile-menu-btn" onclick="toggleSidebar()">
        <i class="fas fa-comments"></i>
    </button>

    <div class="chat-container">
        <!-- Sidebar des conversations -->
        <div class="conversations-sidebar" id="sidebar">
            <div style="padding: 20px; border-bottom: 1px solid #e0e0e0;">
                <h3 style="margin: 0; color: #2c3e50;">Messages</h3>
            </div>
            <div id="conversations-list">
                <!-- Les conversations seront chargées ici -->
            </div>
        </div>

        <!-- Zone de chat principale -->
        <div class="chat-main">
            <div id="empty-state" class="empty-state">
                <i class="fas fa-comments"></i>
                <h3>Sélectionnez une conversation</h3>
                <p>Choisissez une conversation dans la liste pour commencer à discuter</p>
            </div>

            <div id="chat-area" style="display: none;">
                <div class="chat-header">
                    <div class="message-avatar" id="chat-avatar">
                        <span id="chat-initials">?</span>
                    </div>
                    <div>
                        <div id="chat-name" style="font-weight: 600;">Sélectionnez une conversation</div>
                        <div id="chat-status" style="font-size: 12px; opacity: 0.8;">En ligne</div>
                    </div>
                </div>

                <div class="chat-messages" id="messages-container">
                    <!-- Les messages seront chargés ici -->
                </div>

                <div class="typing-indicator" id="typing-indicator">
                    <i class="fas fa-ellipsis-h"></i> L'autre personne est en train d'écrire...
                </div>

                <div class="chat-input">
                    <div class="input-group">
                        <input type="file" id="file-input" style="display: none;" accept="image/*,.pdf,.doc,.docx">
                        <button class="file-upload-btn" onclick="document.getElementById('file-input').click()">
                            <i class="fas fa-paperclip"></i>
                        </button>
                        <input type="text" class="message-input" id="message-input" 
                               placeholder="Tapez votre message..." 
                               onkeypress="handleKeyPress(event)">
                        <button class="send-btn" onclick="sendMessage()">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.socket.io/4.5.0/socket.io.min.js"></script>
    <script>
        let currentConversation = null;
        let socket = null;
        let lastMessageId = 0;

        // Initialiser Socket.io pour le temps réel
        function initSocket() {
            socket = io();
            
            socket.on('connect', () => {
                console.log('Connecté au serveur de messagerie');
            });

            socket.on('new_message', (message) => {
                if (currentConversation && (
                    (message.id_expediteur === currentConversation && message.id_destinataire === {{user.id}}) ||
                    (message.id_expediteur === {{user.id}} && message.id_destinataire === currentConversation)
                )) {
                    addMessageToChat(message);
                    lastMessageId = Math.max(lastMessageId, message.id);
                }
                updateConversations();
            });

            socket.on('typing', (data) => {
                if (data.userId === currentConversation) {
                    document.getElementById('typing-indicator').classList.add('active');
                }
            });

            socket.on('stop_typing', (data) => {
                if (data.userId === currentConversation) {
                    document.getElementById('typing-indicator').classList.remove('active');
                }
            });
        }

        // Charger les conversations
        async function loadConversations() {
            try {
                const response = await fetch('/messages');
                const conversations = await response.json();
                
                const container = document.getElementById('conversations-list');
                container.innerHTML = '';

                conversations.forEach(conv => {
                    const item = createConversationItem(conv);
                    container.appendChild(item);
                });
            } catch (error) {
                console.error('Erreur:', error);
            }
        }

        // Créer un élément de conversation
        function createConversationItem(conv) {
            const div = document.createElement('div');
            div.className = 'conversation-item';
            div.onclick = () => openConversation(conv.other_user_id, conv.other_user);
            
            const initials = conv.other_user?.nom_complet?.split(' ').map(n => n[0]).join('').toUpperCase() || '?';
            
            div.innerHTML = `
                <div class="conversation-avatar" style="background: ${getUserColor(conv.other_user_id)};">
                    ${initials}
                </div>
                <div class="conversation-info">
                    <div class="conversation-name">${conv.other_user?.nom_complet || 'Utilisateur inconnu'}</div>
                    <div class="conversation-last-message">${conv.last_message || 'Aucun message'}</div>
                </div>
                <div class="conversation-meta">
                    <div>${formatTime(conv.last_message_time)}</div>
                    ${conv.unread_count > 0 ? `<div class="unread-badge">${conv.unread_count}</div>` : ''}
                </div>
            `;
            
            return div;
        }

        // Ouvrir une conversation
        async function openConversation(userId, user) {
            currentConversation = userId;
            
            // Mettre à jour l'interface
            document.getElementById('empty-state').style.display = 'none';
            document.getElementById('chat-area').style.display = 'block';
            
            // Mettre à jour l'en-tête
            const initials = user?.nom_complet?.split(' ').map(n => n[0]).join('').toUpperCase() || '?';
            document.getElementById('chat-initials').textContent = initials;
            document.getElementById('chat-name').textContent = user?.nom_complet || 'Utilisateur';
            
            // Mettre à jour la sélection dans la sidebar
            document.querySelectorAll('.conversation-item').forEach(item => {
                item.classList.remove('active');
            });
            event.currentTarget.classList.add('active');
            
            // Charger les messages
            await loadMessages(userId);
            
            // Fermer la sidebar sur mobile
            if (window.innerWidth <= 768) {
                document.getElementById('sidebar').classList.remove('show');
            }
        }

        // Charger les messages d'une conversation
        async function loadMessages(userId) {
            try {
                const response = await fetch(`/messages/${userId}`);
                const messages = await response.json();
                
                const container = document.getElementById('messages-container');
                container.innerHTML = '';
                
                messages.forEach(message => {
                    addMessageToChat(message);
                    lastMessageId = Math.max(lastMessageId, message.id);
                });
                
                // Scroller en bas
                container.scrollTop = container.scrollHeight;
            } catch (error) {
                console.error('Erreur:', error);
            }
        }

        // Ajouter un message au chat
        function addMessageToChat(message) {
            const container = document.getElementById('messages-container');
            const isSent = message.id_expediteur === {{user.id}};
            
            const messageDiv = document.createElement('div');
            messageDiv.className = `message ${isSent ? 'sent' : 'received'}`;
            
            const initials = isSent ? 
                '{{user.nom_complet}}'.split(' ').map(n => n[0]).join('').toUpperCase() :
                (message.expediteur_nom || '?').split(' ').map(n => n[0]).join('').toUpperCase();
            
            messageDiv.innerHTML = `
                <div class="message-avatar" style="background: ${getUserColor(message.id_expediteur)};">
                    ${initials}
                </div>
                <div class="message-content">
                    <div>${message.contenu}</div>
                    ${message.fichier_path ? `
                        <div class="message-file">
                            <i class="fas fa-file"></i>
                            ${message.fichier_path.split('/').pop()}
                        </div>
                    ` : ''}
                    <div class="message-time">${formatTime(message.date_creation)}</div>
                </div>
            `;
            
            container.appendChild(messageDiv);
            container.scrollTop = container.scrollHeight;
        }

        // Envoyer un message
        async function sendMessage() {
            const input = document.getElementById('message-input');
            const content = input.value.trim();
            
            if (!content || !currentConversation) return;
            
            try {
                const response = await fetch('/messages/send', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        id_destinataire: currentConversation,
                        contenu: content,
                        type_message: 'TEXT'
                    })
                });
                
                if (response.ok) {
                    input.value = '';
                    // Le message sera ajouté automatiquement via Socket.io
                }
            } catch (error) {
                console.error('Erreur:', error);
            }
        }

        // Gérer l'upload de fichier
        document.getElementById('file-input').addEventListener('change', async function(e) {
            const file = e.target.files[0];
            if (!file || !currentConversation) return;
            
            const formData = new FormData();
            formData.append('file', file);
            formData.append('id_destinataire', currentConversation);
            formData.append('type_message', 'FILE');
            
            try {
                const response = await fetch('/messages/send', {
                    method: 'POST',
                    body: formData
                });
                
                if (response.ok) {
                    e.target.value = '';
                }
            } catch (error) {
                console.error('Erreur:', error);
            }
        });

        // Gérer les touches
        function handleKeyPress(event) {
            if (event.key === 'Enter' && !event.shiftKey) {
                event.preventDefault();
                sendMessage();
            }
        }

        // Toggle sidebar sur mobile
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('show');
        }

        // Fonctions utilitaires
        function getUserColor(userId) {
            const colors = ['#3498db', '#e74c3c', '#27ae60', '#f39c12', '#9b59b6', '#1abc9c', '#34495e', '#e67e22'];
            return colors[Math.abs(userId) % colors.length];
        }

        function formatTime(dateString) {
            const date = new Date(dateString);
            const now = new Date();
            const diff = now - date;
            
            if (diff < 60000) return 'À l\'instant';
            if (diff < 3600000) return `${Math.floor(diff / 60000)} min`;
            if (diff < 86400000) return `${Math.floor(diff / 3600000)} h`;
            if (diff < 604800000) return `${Math.floor(diff / 86400000)} j`;
            
            return date.toLocaleDateString('fr-FR');
        }

        // Initialisation
        document.addEventListener('DOMContentLoaded', () => {
            loadConversations();
            initSocket();
            
            // Vérifier les nouveaux messages toutes les 30 secondes
            setInterval(() => {
                if (currentConversation) {
                    // Polling pour les nouveaux messages
                    fetch(`/messages/${currentConversation}/new?lastMessageId=${lastMessageId}`)
                        .then(response => response.json())
                        .then(messages => {
                            messages.forEach(message => {
                                addMessageToChat(message);
                                lastMessageId = Math.max(lastMessageId, message.id);
                            });
                        });
                }
            }, 30000);
        });
    </script>
</body>
</html>
