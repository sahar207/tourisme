<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} | Tunisie Authentique</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;700&family=Space+Grotesk:wght@300;400;500;700&display=swap" rel="stylesheet">
  
  <!-- Modern Nature-Inspired Theme -->
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'ocean-blue': '#0077FF',
            'ocean-light': '#00A8FF',
            'ocean-dark': '#0056CC',
            'sand-dune': '#FFE5B4',
            'sand-warm': '#FFD700',
            'mountain-gray': '#8B9DC3',
            'mountain-dark': '#4A5568',
            'desert-orange': '#FF6B35',
            'desert-pink': '#FF1493',
            'city-teal': '#00CED1',
            'city-navy': '#2C3E50',
            'sage-green': '#32CD32',
            'lavender': '#E6E6FA',
            'coral': '#FF7F50',
            'mist': '#F0F4F8',
            'neon-purple': '#9D4EDD',
            'neon-cyan': '#00FFFF',
            'vibrant-pink': '#FF69B4'
          },
          fontFamily: {
            'inter': ['Inter', 'sans-serif'],
            'playfair': ['Playfair Display', 'serif'],
            'space': ['Space Grotesk', 'sans-serif']
          },
          spacing: {
            '18': '4.5rem',
            '88': '22rem',
            '128': '32rem',
            '112': '28rem'
          },
          animation: {
            'float': 'float 4s ease-in-out infinite',
            'wave': 'wave 8s linear infinite',
            'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
            'slide-up': 'slideUp 0.6s ease-out',
            'slide-down': 'slideDown 0.6s ease-out',
            'fade-in': 'fadeIn 0.8s ease-out',
            'scale-in': 'scaleIn 0.4s ease-out',
            'bounce-in': 'bounceIn 0.8s ease-out',
            'glow': 'glow 2s ease-in-out infinite alternate',
            'rotate': 'rotate 20s linear infinite'
          },
          keyframes: {
            float: {
              '0%, 100%': { transform: 'translateY(0px)' },
              '50%': { transform: 'translateY(-15px)' }
            },
            wave: {
              '0%': { transform: 'translateX(0)' },
              '100%': { transform: 'translateX(-100%)' }
            },
            slideUp: {
              '0%': { transform: 'translateY(30px)', opacity: '0' },
              '100%': { transform: 'translateY(0)', opacity: '1' }
            },
            slideDown: {
              '0%': { transform: 'translateY(-100%)', opacity: '0' },
              '100%': { transform: 'translateY(0)', opacity: '1' }
            },
            fadeIn: {
              '0%': { opacity: '0' },
              '100%': { opacity: '1' }
            },
            scaleIn: {
              '0%': { transform: 'scale(0.8)', opacity: '0' },
              '100%': { transform: 'scale(1)', opacity: '1' }
            },
            bounceIn: {
              '0%': { transform: 'scale(0.3)', opacity: '0' },
              '50%': { transform: 'scale(1.05)' },
              '70%': { transform: 'scale(0.9)' },
              '100%': { transform: 'scale(1)', opacity: '1' }
            },
            glow: {
              '0%': { filter: 'brightness(1) drop-shadow(0 0 5px rgba(0, 119, 255, 0.5))' },
              '100%': { filter: 'brightness(1.2) drop-shadow(0 0 20px rgba(0, 119, 255, 0.8))' }
            },
            rotate: {
              '0%': { transform: 'rotate(0deg)' },
              '100%': { transform: 'rotate(360deg)' }
            }
          }
        }
      }
    }
  </script>
  
  <style>
    body {
      font-family: 'Inter', sans-serif;
    }
    
    .glass-morphism { 
      background: rgba(255, 255, 255, 0.7); 
      backdrop-filter: blur(20px); 
      border: 1px solid rgba(0, 0, 0, 0.1);
      box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.1);
    }
    
    .glass-dark { 
      background: rgba(0, 0, 0, 0.05); 
      backdrop-filter: blur(25px); 
      border: 1px solid rgba(0, 0, 0, 0.1);
      box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.15);
    }
    
    .nature-gradient {
      background: linear-gradient(135deg, #0077FF 0%, #00A8FF 25%, #32CD32 50%, #FFD700 75%, #9D4EDD 100%);
    }
    
    .ocean-gradient {
      background: linear-gradient(135deg, #0077FF 0%, #00A8FF 50%, #00CED1 100%);
    }
    
    .desert-gradient {
      background: linear-gradient(135deg, #FF6B35 0%, #FFD700 50%, #FF1493 100%);
    }
    
    .mountain-gradient {
      background: linear-gradient(135deg, #8B9DC3 0%, #4A5568 50%, #2C3E50 100%);
    }
    
    .nature-pattern {
      background-image: 
        radial-gradient(circle at 20% 80%, rgba(255, 107, 53, 0.05) 0%, transparent 50%),
        radial-gradient(circle at 80% 20%, rgba(0, 119, 255, 0.05) 0%, transparent 50%),
        radial-gradient(circle at 40% 40%, rgba(50, 205, 50, 0.03) 0%, transparent 50%);
    }
    
    .card-hover { 
      transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1); 
    }
    
    .card-hover:hover { 
      transform: translateY(-8px) scale(1.02) rotateX(5deg); 
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15), 0 0 30px rgba(0, 119, 255, 0.1);
    }
    
    .text-shadow-glow {
      text-shadow: 0 0 15px rgba(0, 119, 255, 0.2), 2px 2px 4px rgba(0, 0, 0, 0.1);
    }
    
    .button-glow {
      box-shadow: 0 4px 15px rgba(0, 119, 255, 0.3);
      transition: all 0.2s ease;
      position: relative;
      overflow: hidden;
    }
    
    .button-glow::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
      transition: left 0.5s;
    }
    
    .button-glow:hover::before {
      left: 100%;
    }
    
    .button-glow:hover {
      box-shadow: 0 6px 25px rgba(0, 119, 255, 0.4);
      transform: translateY(-2px);
    }
    
    .floating-element {
      animation: float 4s ease-in-out infinite;
    }
    
    .wave-animation {
      background: linear-gradient(90deg, transparent, rgba(0, 119, 255, 0.05), transparent);
      animation: wave 8s linear infinite;
    }
    
    .neon-text {
      color: #0077FF;
      text-shadow: 0 0 10px #0077FF, 0 0 20px #0077FF, 0 0 30px #0077FF;
    }
    
    .gradient-border {
      position: relative;
      background: linear-gradient(45deg, #0077FF, #00A8FF, #32CD32, #FFD700);
      padding: 2px;
      border-radius: 1rem;
    }
    
    .gradient-border::before {
      content: '';
      position: absolute;
      inset: 2px;
      background: inherit;
      border-radius: 0.8rem;
      z-index: -1;
    }
  </style>
</head>
<body class="bg-gradient-to-br from-blue-50 via-white to-green-50 min-h-screen text-gray-900 overflow-x-hidden">

  <!-- MAIN CONTENT (no navbar/footer) -->
  <main class="min-h-screen animate-fade-in">
    {{{body}}}
  </main>

</body>
</html>
