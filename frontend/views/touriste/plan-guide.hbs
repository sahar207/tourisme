<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Plans de {{guide.nom_complet}} - Tunisie Authentique</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <style>
    .glass { 
      background: rgba(255,255,255,0.15); 
      backdrop-filter: blur(20px); 
      border: 1px solid rgba(255,255,255,0.25); 
    }
    .card-hover { 
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
    }
    .card-hover:hover { 
      transform: translateY(-10px) scale(1.02); 
      box-shadow: 0 25px 50px rgba(0,0,0,0.3);
    }
  </style>
</head>
<body class="bg-gradient-to-br from-purple-900 via-blue-900 to-indigo-900 min-h-screen text-white">

 

  <!-- Hero Section -->
  <section class="pt-32 pb-16 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <div class="flex items-center justify-center mb-8">
          {{#if guide.photo_profil}}
          <img src="{{guide.photo_profil}}" alt="{{guide.nom_complet}}" class="w-32 h-32 rounded-full object-cover border-4 border-yellow-400 shadow-2xl">
          {{else}}
          <div class="w-32 h-32 bg-gradient-to-br from-yellow-400 to-orange-500 rounded-full flex items-center justify-center text-4xl font-black shadow-2xl">
            {{guide.nom_complet.[0]}}
          </div>
          {{/if}}
        </div>
        <h1 class="text-4xl md:text-6xl font-black mb-4">
          Plans de <span class="text-yellow-400">{{guide.nom_complet}}</span>
        </h1>
        <p class="text-xl opacity-90 max-w-2xl mx-auto">
          Découvrez tous les circuits touristiques proposés par notre guide certifié
        </p>
      </div>
    </div>
  </section>

  <!-- Plans Grid -->
  <section class="px-6 pb-32">
    <div class="max-w-7xl mx-auto">
      {{#if plans.length}}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {{#each plans}}
        <div class="glass rounded-3xl p-8 card-hover border-2 border-white/20 hover:border-yellow-400">
          <!-- Header Plan -->
          <div class="flex items-start justify-between mb-6">
            <div>
              <h3 class="text-2xl font-black mb-2">{{titre}}</h3>
              <p class="text-lg opacity-80 leading-relaxed">{{description}}</p>
            </div>
            {{#if prix}}
            <div class="text-3xl font-black text-yellow-400">
              {{prix}} TND
            </div>
            {{/if}}
          </div>

          <!-- Dates -->
          <div class="flex items-center gap-6 mb-6 text-lg">
            <div class="flex items-center">
              <i class="fas fa-calendar-alt mr-2 text-emerald-400"></i>
              <span>Début: {{date_debut}}</span>
            </div>
            <div class="flex items-center">
              <i class="fas fa-calendar-check mr-2 text-blue-400"></i>
              <span>Fin: {{date_fin}}</span>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex flex-col sm:flex-row gap-4 pt-6 border-t border-white/30">
            <a href="/plan/{{id}}" class="flex-1 bg-gradient-to-r from-blue-500 to-indigo-600 px-6 py-4 rounded-2xl font-bold text-center text-white card-hover">
              <i class="fas fa-info-circle mr-2"></i>
              Voir Détails
            </a>
            {{#if ../user}}
            <a href="/reservations/create/{{id}}" class="flex-1 bg-gradient-to-r from-yellow-400 to-orange-500 px-6 py-4 rounded-2xl font-bold text-center text-gray-900 card-hover">
              <i class="fas fa-calendar-plus mr-2"></i>
              Réserver
            </a>
            {{else}}
            <a href="/login" class="flex-1 glass px-6 py-4 rounded-2xl font-bold text-center card-hover">
              <i class="fas fa-sign-in-alt mr-2"></i>
              Connectez-vous pour réserver
            </a>
            {{/if}}
          </div>
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="text-center py-32">
        <i class="fas fa-route text-8xl text-white/20 mb-12"></i>
        <h2 class="text-4xl font-black mb-6">Aucun plan disponible</h2>
        <p class="text-2xl opacity-80 mb-12 max-w-2xl mx-auto">
          {{guide.nom_complet}} n'a pas encore publié de circuits touristiques
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/" class="glass px-12 py-6 rounded-3xl font-bold text-xl card-hover">
            <i class="fas fa-arrow-left mr-3"></i>
            Retour à l'accueil
          </a>
          <a href="/touriste/gouvernorat/1" class="bg-gradient-to-r from-yellow-400 to-orange-500 px-12 py-6 rounded-3xl font-bold text-xl card-hover">
            <i class="fas fa-users mr-3"></i>
            Voir d'autres guides
          </a>
        </div>
      </div>
      {{/if}}
    </div>
  </section>

  <!-- Footer -->
  <footer class="glass p-12 text-center border-t border-white/20">
    <p class="text-lg opacity-75">&copy; 2026 Tunisie Authentique. Tous droits réservés.</p>
  </footer>

</body>
</html>
